.ipynb_checkpoints/
*.ipynb~

# Model artifacts (optional — uncomment to exclude large binaries)
# model.pkl
# encoders.pkl

# EDA plots (auto-generated)
static/assets/eda/

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets / credentials
*.env
.env
secrets.py

# Logs
*.log
